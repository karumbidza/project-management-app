// FOLLO SLA
// FOLLO GANTT-2
// FOLLO PERF
// FOLLO WORKFLOW
generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ENUMS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum WorkspaceRole {
    ADMIN
    MEMBER
}

enum ProjectRole {
    OWNER
    MANAGER
    CONTRIBUTOR
    VIEWER
}

enum TaskStatus {
    TODO
    IN_PROGRESS
    BLOCKED
    PENDING_APPROVAL
    DONE
}

enum TaskType {
    TASK
    BUG
    FEATURE
    IMPROVEMENT
    MILESTONE
    OTHER
}

enum ProjectStatus {
    ACTIVE
    PLANNING
    COMPLETED
    ON_HOLD
    CANCELLED
}

enum Priority {
    LOW
    MEDIUM
    HIGH
    CRITICAL
}

enum NotificationType {
    TASK_ASSIGNED
    TASK_UPDATED
    TASK_STARTING_SOON
    TASK_OVERDUE
    PREDECESSOR_COMPLETE
    COMMENT_ADDED
    PROJECT_INVITE
    DELAY_ALERT
    SLA_WARNING
    BLOCKER_RAISED
    TASK_APPROVED
}

enum InviteStatus {
    PENDING
    ACCEPTED
    EXPIRED
    CANCELLED
}

enum ActivityType {
    TASK_CREATED
    TASK_UPDATED
    STATUS_CHANGED
    ASSIGNEE_CHANGED
    DUE_DATE_CHANGED
    DELAY_REPORTED
    COMMENT_ADDED
    DEPENDENCY_ADDED
    DEPENDENCY_REMOVED
    HANDOFF_INITIATED
    HANDOFF_COMPLETED
}

// Comment media types (FOLLO MEDIA)
enum CommentType {
    TEXT
    IMAGE
    VIDEO
    AUDIO
    FILE
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// USER MODEL
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model User {
    id        String   @id
    name      String
    email     String   @unique
    image     String   @default("")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    workspaces       WorkspaceMember[]
    projectsOwned    Project[]         @relation("ProjectOwner")
    projectMembers   ProjectMember[]
    tasksAssigned    Task[]            @relation("TaskAssignee")
    tasksCreated     Task[]            @relation("TaskCreator")
    comments         Comment[]
    ownedWorkspaces  Workspace[]
    activities       TaskActivity[]
    notifications    Notification[]
    invitationsSent  Invitation[]      @relation("InvitedBy")
    contractorScore ContractorScore?
    pushSubscriptions PushSubscription[]
    projectComments  ProjectComment[]  // FOLLO PROJECT-OVERVIEW

    // Indexes for query performance
    @@index([email])
    @@index([createdAt])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// WORKSPACE MODELS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Workspace {
    id          String   @id
    name        String
    slug        String   @unique
    description String?
    settings    Json     @default("{}")
    ownerId     String
    createdAt   DateTime @default(now())
    image_url   String   @default("")
    updatedAt   DateTime @updatedAt

    // Relations
    members  WorkspaceMember[]
    projects Project[]
    owner    User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)

    // Indexes
    @@index([ownerId])
    @@index([slug])
}

model WorkspaceMember {
    id          String        @id @default(uuid())
    userId      String
    workspaceId String
    message     String        @default("")
    role        WorkspaceRole @default(MEMBER)
    joinedAt    DateTime      @default(now())

    // Relations
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

    // Constraints & Indexes
    @@unique([userId, workspaceId])
    @@index([workspaceId])
    @@index([userId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// PROJECT MODELS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Project {
    id          String        @id @default(uuid())
    name        String
    description String?
    priority    Priority      @default(MEDIUM)
    status      ProjectStatus @default(ACTIVE)
    startDate   DateTime?
    endDate     DateTime?
    ownerId     String
    workspaceId String
    progress    Int           @default(0)
    budget      Decimal?      @db.Decimal(12, 2)
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt

    // Relations
    owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
    workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    members         ProjectMember[]
    tasks           Task[]
    invitations     Invitation[]
    projectComments ProjectComment[] // FOLLO PROJECT-OVERVIEW
    pinnedLinks     ProjectLink[]    // FOLLO PROJECT-OVERVIEW

    // Indexes
    @@index([workspaceId])
    @@index([ownerId])
    @@index([status])
    @@index([createdAt])
}

model ProjectMember {
    id        String      @id @default(uuid())
    userId    String
    projectId String
    role      ProjectRole @default(CONTRIBUTOR)
    isActive  Boolean     @default(true)
    joinedAt  DateTime    @default(now())

    // Relations
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    // Constraints & Indexes
    @@unique([userId, projectId])
    @@index([projectId])
    @@index([userId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// TASK MODELS (with dependencies)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Task {
    id          String     @id @default(uuid())
    projectId   String
    title       String
    description String?
    status      TaskStatus @default(TODO)
    type        TaskType?  @default(TASK)  // FOLLO WORKFLOW — optional, hidden from UI
    priority    Priority   @default(MEDIUM)
    priorityOverride Boolean @default(false)  // FOLLO WORKFLOW — when true, skip auto-calc
    
    // Assignment
    assigneeId  String?
    createdById String
    
    // Scheduling - Planned vs Actual
    plannedStartDate DateTime?
    plannedEndDate   DateTime?
    actualStartDate  DateTime?
    actualEndDate    DateTime?
    dueDate          DateTime
    
    // Delay Tracking
    isDelayed     Boolean @default(false)
    delayDays     Int     @default(0)
    delayReason   String?
    
    // SLA state machine
    slaStatus           String    @default("HEALTHY")
    // HEALTHY | AT_RISK | PENDING_APPROVAL | BLOCKED |
    // BREACHED | RESOLVED_ON_TIME | RESOLVED_LATE

    // Approval workflow
    submittedAt         DateTime?
    submittedById       String?
    approvedAt          DateTime?
    approvedById        String?
    rejectedAt          DateTime?
    rejectedById        String?
    rejectionReason     String?

    // Blocker system
    blockerRaisedAt     DateTime?
    blockerRaisedById   String?
    blockerDescription  String?
    blockerResolvedAt   DateTime?
    blockerResolvedById String?
    requiresPhotoOnBlock Boolean  @default(true)

    // SLA clock management
    slaClockStartedAt   DateTime?
    slaClockPausedAt    DateTime?
    slaTotalPausedMs    Int       @default(0)

    // Scoring impact
    slaBreachCount      Int       @default(0)
    slaOnTimeCount      Int       @default(0)

    // Completion
    completionWeight    Int       @default(1)
    completionNotes     String?
    completionPhotos    Json?     // Array of photo URLs
    declarationConfirmed Boolean  @default(false)

    // Deadline extension request (FOLLO WORKFLOW)
    extensionStatus         String    @default("NONE") // NONE | PENDING | APPROVED | DENIED
    extensionRequestedAt    DateTime?
    extensionRequestedById  String?
    extensionReason         String?
    extensionProposedDate   DateTime?
    extensionOriginalDueDate DateTime?
    extensionApprovedAt     DateTime?
    extensionApprovedById   String?
    extensionDeniedAt       DateTime?
    extensionDeniedById     String?

    // FOLLO GANTT-2 — baseline dates (set once on creation, never updated)
    // These preserve the original schedule so PM can see slip
    baselineDueDate       DateTime?
    baselinePlannedStart  DateTime?
    baselinePlannedEnd    DateTime?

    // Task ordering for Gantt/timeline
    sortOrder     Int     @default(0)
    
    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
    assignee     User?          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
    createdBy    User           @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
    comments     Comment[]
    activities   TaskActivity[]
    slaEvents    SlaEvent[]
    
    // Task Dependencies (self-referential)
    predecessors TaskDependency[] @relation("TaskSuccessor")
    successors   TaskDependency[] @relation("TaskPredecessor")

    // Indexes for performance
    @@index([projectId])
    @@index([assigneeId])
    @@index([status])
    @@index([dueDate])
    @@index([isDelayed])
    @@index([slaStatus])
    @@index([createdAt])
    // FOLLO PERF — compound indexes for common query patterns
    @@index([projectId, status])
    @@index([assigneeId, status])
    @@index([projectId, slaStatus])
}

model TaskDependency {
    id            String   @id @default(uuid())
    predecessorId String
    successorId   String
    lagDays       Int      @default(0)  // Days between predecessor end and successor start
    createdAt     DateTime @default(now())

    // Relations
    predecessor Task @relation("TaskPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
    successor   Task @relation("TaskSuccessor", fields: [successorId], references: [id], onDelete: Cascade)

    // Constraints
    @@unique([predecessorId, successorId])
    @@index([predecessorId])
    @@index([successorId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ACTIVITY & AUDIT TRAIL
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model TaskActivity {
    id        String       @id @default(uuid())
    taskId    String
    userId    String
    type      ActivityType
    message   String
    metadata  Json         @default("{}")  // Store old/new values for audit
    createdAt DateTime     @default(now())

    // Relations
    task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Indexes
    @@index([taskId])
    @@index([userId])
    @@index([type])
    @@index([createdAt])
}

model Comment {
    id        String   @id @default(uuid())
    content   String?  // Optional for pure media comments
    userId    String
    taskId    String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    // ━━━ Media fields (FOLLO MEDIA) ━━━
    type           CommentType @default(TEXT)  // text | image | video | audio | file
    url            String?     // CDN URL for media (R2 or Mux stream)
    fileKey        String?     // R2 storage key for deletion
    thumbnailUrl   String?     // Video thumbnail from Mux
    duration       Float?      // Video/audio duration in seconds
    sizeBytes      Int?        // File size for display
    fileName       String?     // Original filename for downloads
    muxUploadId    String?     // Mux upload ID for polling status
    muxAssetId     String?     // Mux asset ID for deletion
    muxPlaybackId  String?     // Mux playback ID for streaming

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

    // Indexes
    @@index([taskId])
    @@index([userId])
    @@index([createdAt])
    @@index([type])
    // FOLLO PERF — compound index for ordered comments per task
    @@index([taskId, createdAt])
}

model Notification {
    id        String           @id @default(uuid())
    userId    String
    type      NotificationType
    title     String
    message   String
    metadata  Json             @default("{}")  // Store related IDs (taskId, projectId, etc.)
    isRead    Boolean          @default(false)
    readAt    DateTime?
    createdAt DateTime         @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Indexes
    @@index([userId])
    @@index([isRead])
    @@index([createdAt])
    @@index([type])
    // FOLLO PERF — compound indexes for notification queries
    @@index([userId, isRead])
    @@index([userId, createdAt])
}

model Invitation {
    id          String       @id @default(uuid())
    email       String
    projectId   String
    role        ProjectRole  @default(CONTRIBUTOR)
    status      InviteStatus @default(PENDING)
    invitedById String
    token       String       @unique @default(uuid())
    message     String?
    expiresAt   DateTime
    createdAt   DateTime     @default(now())
    acceptedAt  DateTime?

    // Relations
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    invitedBy User    @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

    // Indexes
    @@unique([email, projectId])
    @@index([email])
    @@index([token])
    @@index([status])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// SLA SYSTEM (FOLLO SLA)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model ContractorScore {
    id        String   @id @default(cuid())
    userId    String   @unique
    score     Int      @default(100)
    breaches  Int      @default(0)
    onTime    Int      @default(0)
    rejections Int     @default(0)
    blocked   Int      @default(0)
    updatedAt DateTime @updatedAt
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([score])
}

model SlaEvent {
    id          String   @id @default(cuid())
    taskId      String
    type        String
    // CLOCK_STARTED | CLOCK_PAUSED | CLOCK_RESUMED | WARNING_24HR |
    // WARNING_2HR | BREACHED | SUBMITTED | APPROVED | REJECTED |
    // BLOCKER_RAISED | BLOCKER_RESOLVED | SCORE_UPDATED
    triggeredBy String?
    metadata    Json?
    createdAt   DateTime @default(now())
    task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

    @@index([taskId])
    @@index([type])
    @@index([createdAt])
    // FOLLO PERF — compound index for ordered events per task
    @@index([taskId, createdAt])
}

model TaskTemplate {
    id               String   @id @default(cuid())
    workspaceId      String
    name             String
    description      String?
    type             TaskType @default(TASK)
    priority         Priority @default(MEDIUM)
    durationDays     Int      @default(1)
    completionWeight Int      @default(1)
    createdById      String
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    checklist        TemplateChecklistItem[]
    projectTasks     ProjectTemplateTask[]

    @@index([workspaceId])
    @@index([createdById])
}

model TemplateChecklistItem {
    id         String   @id @default(cuid())
    templateId String
    label      String
    sortOrder  Int      @default(0)
    createdAt  DateTime @default(now())

    template TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

    @@index([templateId])
}

model ProjectTemplate {
    id          String   @id @default(cuid())
    workspaceId String
    name        String
    description String?
    createdById String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    tasks ProjectTemplateTask[]

    @@index([workspaceId])
    @@index([createdById])
}

model ProjectTemplateTask {
    id                String   @id @default(cuid())
    projectTemplateId String
    taskTemplateId    String
    sortOrder         Int      @default(0)
    offsetDays        Int      @default(0) // Offset from project start
    predecessorIndex  Int?     // Index of another task in this template (for auto-wiring dependencies)

    projectTemplate ProjectTemplate @relation(fields: [projectTemplateId], references: [id], onDelete: Cascade)
    taskTemplate    TaskTemplate    @relation(fields: [taskTemplateId], references: [id], onDelete: Cascade)

    @@index([projectTemplateId])
    @@index([taskTemplateId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// PUSH SUBSCRIPTIONS (FOLLO NOTIFY)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model PushSubscription {
    id        String   @id @default(uuid())
    userId    String
    endpoint  String   @unique
    p256dh    String
    auth      String
    userAgent String?
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// PROJECT OVERVIEW MODELS (FOLLO PROJECT-OVERVIEW)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model ProjectComment {
    id        String   @id @default(cuid())
    content   String
    projectId String
    userId    String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([projectId, createdAt])
}

model ProjectLink {
    id        String   @id @default(cuid())
    projectId String
    label     String
    url       String
    icon      String?
    pinnedBy  String
    createdAt DateTime @default(now())

    project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([projectId])
}
